# Stage 1: Build a parameterized adapter binary
FROM golang:1.24-alpine AS builder

ARG BINARY_NAME

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/${BINARY_NAME} ./cmd/${BINARY_NAME}

# Stage 2: Minimal runtime image
FROM alpine:3.21

ARG BINARY_NAME

RUN apk add --no-cache ca-certificates

COPY --from=builder /bin/${BINARY_NAME} /usr/local/bin/adapter

USER 65534

ENTRYPOINT ["adapter"]
